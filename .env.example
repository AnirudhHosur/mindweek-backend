# MindWeek Backend Environment Variables

# Google Gemini API Key (required)
GEMINI_API_KEY=your_actual_api_key_here

# Gemini Model Configuration
GEMINI_MODEL=gemini-2.5-flash

# Gemini Embedding Model Configuration  
GEMINI_EMBED_MODEL=gemini-embedding-001

# Database configuration (optional - defaults to local SQLite)
# DATABASE_URL=sqlite:///./brain.db

# Example environment variables for MindWeek Backend
CLERK_JWKS_URL=your_clerk_jwks_url_here

# Other potential environment variables (as needed)
# DEBUG=true
# LOG_LEVEL=info